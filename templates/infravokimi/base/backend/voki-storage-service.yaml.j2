apiVersion: apps/v1
kind: Deployment
metadata:
  name: vokimi-storage-service
  annotations:
    argocd.argoproj.io/sync-wave: "1"
  labels:
    app: vokimi-storage-service
    tier: backend
spec:
  selector:
    matchLabels:
      app: vokimi-storage-service
  template:
    metadata:
      labels:
        app: vokimi-storage-service
        tier: backend
    spec:
      imagePullSecrets:
        - name: gitlab-registry-secret
      initContainers:
        - name: wait-for-rabbitmq
          image: curlimages/curl:latest
          command:
            - /bin/sh
            - -c
            - |
              echo "Waiting for RabbitMQ..."
              until curl -sf -u "$MessageBroker__Username:$MessageBroker__Password" http://rabbitmq:15672/api/aliveness-test/%2F; do
                sleep 5
              done
              echo "RabbitMQ is ready!"
          envFrom:
            - secretRef:
                name: common-secrets
      containers:
        - name: vokimi-storage-service
          image: "{{ gitlab_container_registry }}/storage:v1.0"
          imagePullPolicy: Always
          ports:
            - containerPort: 8080
              name: http
          envFrom:
            - configMapRef:
                name: common-config
            - secretRef:
                name: common-secrets
          env:
            - name: ServiceName
              value: "StorageService"
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "512Mi"
              cpu: "500m"
          readinessProbe:
            tcpSocket:
              port: 8080
            initialDelaySeconds: 10
            periodSeconds: 10
            failureThreshold: 5
          livenessProbe:
            tcpSocket:
              port: 8080
            initialDelaySeconds: 30
            periodSeconds: 30
---
apiVersion: v1
kind: Service
metadata:
  name: vokimi-storage-service
  annotations:
    argocd.argoproj.io/sync-wave: "-4"
  labels:
    app: vokimi-storage-service
spec:
  selector:
    app: vokimi-storage-service
  ports:
    - name: http
      port: 8080
      targetPort: 8080
