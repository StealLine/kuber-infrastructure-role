# Strategic merge patch for user-profiles-service in staging
# Uncomment / adjust as needed
apiVersion: apps/v1
kind: Deployment
metadata:
  name: user-profiles-service
spec:
  replicas: 1
  template:
    spec:
      containers:
        - name: user-profiles-service
          image: "{{ gitlab_container_registry }}/user-profiles:main-stable"
          resources:
            requests:
              memory: "128Mi"
              cpu: "10m"
            limits:
              memory: "512Mi"
              cpu: "500m"
