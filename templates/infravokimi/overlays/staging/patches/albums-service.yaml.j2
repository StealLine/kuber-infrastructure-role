# Strategic merge patch for albums-service in staging
# Uncomment / adjust as needed
apiVersion: apps/v1
kind: Deployment
metadata:
  name: albums-service
spec:
  replicas: 1
  template:
    spec:
      containers:
        - name: albums-service
          image: "{{ gitlab_container_registry }}/albums:main-stable"
          resources:
            requests:
              memory: "128Mi"
              cpu: "10m"
            limits:
              memory: "512Mi"
              cpu: "500m"
