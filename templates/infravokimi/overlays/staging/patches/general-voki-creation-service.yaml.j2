# Strategic merge patch for general-voki-creation-service in staging
# Uncomment / adjust as needed
apiVersion: apps/v1
kind: Deployment
metadata:
  name: general-voki-creation-service
spec:
  replicas: 1
  template:
    spec:
      containers:
        - name: general-voki-creation-service
          image: "{{ gitlab_container_registry }}/general-voki-creation:main-stable"
          resources:
            requests:
              memory: "128Mi"
              cpu: "10m"
            limits:
              memory: "512Mi"
              cpu: "500m"
