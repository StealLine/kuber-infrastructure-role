apiVersion: networking.istio.io/v1
kind: VirtualService
metadata:
  name: minio-console
  annotations:
    argocd.argoproj.io/sync-wave: "4"
spec:
  hosts:
    - "minio-staging.{{ website_domain }}"
  gateways:
    - istio-ingress/cloudflare-gateway
  http:
    - route:
        - destination:
            host: minio
            port:
              number: 9001
